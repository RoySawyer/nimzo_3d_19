#: main_19.cpp:3
msgid "Start next time in normal screen"
msgstr "ابدأ في المرة القادمة على الشاشة العادية"

#: main_19.cpp:7
msgid "Start next time in full screen mode"
msgstr "ابدأ في المرة القادمة في وضع ملء الشاشة"

#: main_19.cpp:9
msgid "If you exit the program from the menu, then the program"
msgstr "إذا قمت بالخروج من البرنامج من القائمة، فسيتم إغلاق البرنامج"

#: main_19.cpp:11
msgid "will restart in normal 2d screen mode."
msgstr "ستتم إعادة التشغيل في وضع الشاشة ثنائي الأبعاد العادي."

#: main_19.cpp:13
msgid "If you exit the program from the engine window toolbar,"
msgstr "إذا قمت بالخروج من البرنامج من شريط أدوات نافذة المحرك،"

#: main_19.cpp:15
msgid "then the program will restart in full screen mode."
msgstr "ثم سيعاد تشغيل البرنامج في وضع ملء الشاشة."

#: main_19.cpp:17
msgid "Alternative - click to take back the reply move and play an alternative move instead."
msgstr "بديل - انقر للتراجع عن حركة الرد ولعب حركة بديلة بدلاً منها."

#: main_19.cpp:19
msgid "To over-ride the default behaviour of this option"
msgstr "لتجاوز السلوك الافتراضي لهذا الخيار"

#: main_19.cpp:21
msgid "Hold down < Ctrl > for the next alternative move in the list"
msgstr "اضغط باستمرار على مفتاح <Ctrl> للانتقال إلى الخطوة البديلة التالية في القائمة"

#: main_19.cpp:23
msgid "Hold down < Shift > for a random alternative move"
msgstr "اضغط باستمرار على مفتاح <Shift> لتنفيذ حركة بديلة عشوائية"

#: main_19.cpp:25
msgid "Hold down < Ctrl > and < Shift > for the best alternative move"
msgstr "اضغط باستمرار على مفتاحي <Ctrl> و <Shift> للحصول على أفضل حركة بديلة"

#: main_19.cpp:27
msgid "on the keyboard, select < File > < Exit 3d > from the main menu,"
msgstr "على لوحة المفاتيح، حدد <ملف> <خروج ثلاثي الأبعاد> من القائمة الرئيسية،"

#: main_19.cpp:29
msgid "To exit the program from the 3d screen, select < File > < Exit program >"
msgstr "للخروج من البرنامج من الشاشة ثلاثية الأبعاد، حدد <ملف> <إنهاء البرنامج>"

#: main_19.cpp:31
msgid "If the want to the program to restart in 3d graphics mode next time,"
msgstr "إذا كنت ترغب في إعادة تشغيل البرنامج في وضع الرسومات ثلاثية الأبعاد في المرة القادمة،"

#: main_19.cpp:33
msgid "then hold down the < Ctrl > key when you select this option."
msgstr "ثم اضغط باستمرار على مفتاح <Ctrl> عند تحديد هذا الخيار."

#: main_19.cpp:35
msgid "Adjourned games  -  Click to load a previously adjourned game."
msgstr "المباريات المؤجلة - انقر لتحميل مباراة تم تأجيلها سابقًا."

#: main_19.cpp:37
msgid "Load an adjourned game"
msgstr "تحميل لعبة مؤجلة"

#: main_19.cpp:39
msgid "Adjourn game"
msgstr "تأجيل المباراة"

#: main_19.cpp:41
msgid "Open the Adjourned game dialog box"
msgstr "افتح مربع حوار اللعبة المؤجلة"

#: main_19.cpp:43
msgid "Adjourned games"
msgstr "مباريات مؤجلة"

#: main_19.cpp:45
msgid "Adjourned game file name"
msgstr "اسم ملف اللعبة المؤجلة"

#: main_19.cpp:47
msgid "Select adjourned game .pgn filename"
msgstr "حدد اسم ملف المباراة المؤجلة بصيغة .pgn"

#: main_19.cpp:49
msgid "Load"
msgstr "حمولة"

#: main_19.cpp:51
msgid "Enter the PGN adjourn game file name"
msgstr "أدخل اسم ملف لعبة PGN المؤجلة"

#: main_19.cpp:52
msgid "Save the current game as adjouned"
msgstr "احفظ اللعبة الحالية باسم "تم تأجيلها""

#: main_19.cpp:53
msgid "Load the adjourned game as current"
msgstr "قم بتحميل اللعبة المؤجلة كنسخة حالية"

#: main_19.cpp:55
msgid "This dialog box allows you to adjourn a game and restart it later."
msgstr "يتيح لك مربع الحوار هذا إيقاف اللعبة مؤقتًا وإعادة تشغيلها لاحقًا."

#: main_19.cpp:57
msgid "Click the < Save > button to save the current game."
msgstr "انقر على زر "حفظ" لحفظ اللعبة الحالية."

#: main_19.cpp:59
msgid "You can them choose the PGN file for saving the game in"
msgstr "يمكنك بعد ذلك اختيار ملف PGN لحفظ اللعبة فيه"

#: main_19.cpp:61
msgid "and then you can enter the game details."
msgstr "وبعد ذلك يمكنك إدخال تفاصيل اللعبة."

#: main_19.cpp:63
msgid "Click the < Load > button to load a previously stored game."
msgstr "انقر فوق زر "تحميل" لتحميل لعبة مخزنة مسبقًا."

#: main_19.cpp:65
msgid "As before you choose the PGN file to load the game from,"
msgstr "كما في السابق، اختر ملف PGN لتحميل اللعبة منه،"

#: main_19.cpp:67
msgid "and then you can pick the game that you want."
msgstr "وبعد ذلك يمكنك اختيار اللعبة التي تريدها."

#: main_19.cpp:69
msgid "If you click < Ok > the game will be loaded, ready for playing."
msgstr "إذا نقرت على "موافق"، فسيتم تحميل اللعبة، وستكون جاهزة للعب."

#: main_19.cpp:71
msgid "Then pick < Play white > or < Play black > depending on which colour"
msgstr "ثم اختر <تشغيل أبيض> أو <تشغيل أسود> حسب اللون المطلوب"

#: main_19.cpp:73
msgid "you had in the adjourned game."
msgstr "كان لديك في المباراة المؤجلة."

#: main_19.cpp:75
msgid "Adjourned games can also be restarted from the rated game dialog box."
msgstr "يمكن أيضًا إعادة تشغيل الألعاب المؤجلة من مربع حوار اللعبة المصنفة."

#: main_19.cpp:77
msgid "If you load a game from there, it will be automatically ready for play,"
msgstr "إذا قمت بتحميل لعبة من هناك، فستكون جاهزة للعب تلقائيًا."

#: main_19.cpp:79
msgid "although your clock will not start until you make a move."
msgstr "مع أن ساعتك لن تبدأ حتى تقوم بحركة."

#: main_19.cpp:81
msgid "Adjourn game dialog box"
msgstr "مربع حوار تأجيل اللعبة"

#: main_19.cpp:83
msgid "Error writing clock config file"
msgstr "خطأ في كتابة ملف إعدادات الساعة"

#: main_19.cpp:85
msgid "Invalid PGN file name"
msgstr "اسم ملف PGN غير صالح"

#: main_19.cpp:87
msgid "Cannot open clock config file"
msgstr "لا يمكن فتح ملف إعدادات الساعة"

#: main_19.cpp:89
msgid "Adjourned game saved"
msgstr "تم حفظ اللعبة المؤجلة"

#: main_19.cpp:91
msgid "Adjourned game loaded"
msgstr "تم تحميل المباراة المؤجلة"

#: main_19.cpp:93
msgid "Error reading clock configuration file, operation cancelled"
msgstr "حدث خطأ في قراءة ملف تكوين الساعة، تم إلغاء العملية."

#: main_19.cpp:95
msgid "Could not open clock configuration file, operation cancelled"
msgstr "تعذر فتح ملف إعدادات الساعة، تم إلغاء العملية."

#: main_19.cpp:97
msgid "Could not find clock configuration file, operation cancelled"
msgstr "تعذر العثور على ملف إعدادات الساعة، تم إلغاء العملية."

#: main_19.cpp:99
msgid "Press < Ok > to transfer the game to the board"
msgstr "اضغط على <موافق> لنقل اللعبة إلى اللوحة"

#: main_19.cpp:101
msgid "Adjourned game options"
msgstr "خيارات اللعبة المؤجلة"
