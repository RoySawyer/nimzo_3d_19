#: main_19.cpp:3
msgid "Start next time in normal screen"
msgstr "دفعه بعد در صفحه عادی شروع کنید"

#: main_19.cpp:7
msgid "Start next time in full screen mode"
msgstr "دفعه بعد در حالت تمام صفحه شروع کنید"

#: main_19.cpp:9
msgid "If you exit the program from the menu, then the program"
msgstr "اگر از برنامه از منو خارج شوید، برنامه"

#: main_19.cpp:11
msgid "will restart in normal 2d screen mode."
msgstr "در حالت صفحه نمایش دوبعدی معمولی مجدداً راه‌اندازی خواهد شد."

#: main_19.cpp:13
msgid "If you exit the program from the engine window toolbar,"
msgstr "اگر از نوار ابزار پنجره موتور از برنامه خارج شوید،"

#: main_19.cpp:15
msgid "then the program will restart in full screen mode."
msgstr "سپس برنامه در حالت تمام صفحه مجدداً راه اندازی می شود."

#: main_19.cpp:17
msgid "Alternative - click to take back the reply move and play an alternative move instead."
msgstr "جایگزین - برای پس گرفتن حرکت پاسخ و اجرای یک حرکت جایگزین، کلیک کنید."

#: main_19.cpp:19
msgid "To over-ride the default behaviour of this option"
msgstr "برای لغو رفتار پیش‌فرض این گزینه"

#: main_19.cpp:21
msgid "Hold down < Ctrl > for the next alternative move in the list"
msgstr "برای حرکت جایگزین بعدی در لیست، <Ctrl> را نگه دارید"

#: main_19.cpp:23
msgid "Hold down < Shift > for a random alternative move"
msgstr "برای یک حرکت تصادفی جایگزین، <Shift> را نگه دارید"

#: main_19.cpp:25
msgid "Hold down < Ctrl > and < Shift > for the best alternative move"
msgstr "برای بهترین حرکت جایگزین، <Ctrl> و <Shift> را نگه دارید."

#: main_19.cpp:27
msgid "on the keyboard, select < File > < Exit 3d > from the main menu,"
msgstr "روی صفحه کلید، <فایل> <خروج از حالت سه‌بعدی> را از منوی اصلی انتخاب کنید،"

#: main_19.cpp:29
msgid "To exit the program from the 3d screen, select < File > < Exit program >"
msgstr "برای خروج از برنامه از صفحه سه‌بعدی، <فایل> <خروج از برنامه> را انتخاب کنید."

#: main_19.cpp:31
msgid "If the want to the program to restart in 3d graphics mode next time,"
msgstr "اگر می‌خواهید برنامه دفعه‌ی بعد در حالت گرافیک سه‌بعدی مجدداً راه‌اندازی شود،"

#: main_19.cpp:33
msgid "then hold down the < Ctrl > key when you select this option."
msgstr "سپس هنگام انتخاب این گزینه، کلید <Ctrl> را نگه دارید."

#: main_19.cpp:35
msgid "Adjourned games  -  Click to load a previously adjourned game."
msgstr "بازی‌های به تعویق افتاده - برای بارگیری یک بازی که قبلاً به تعویق افتاده است، کلیک کنید."

#: main_19.cpp:37
msgid "Load an adjourned game"
msgstr "بارگذاری یک بازی متوقف شده"

#: main_19.cpp:39
msgid "Adjourn game"
msgstr "بازی را به تعویق بیندازید"

#: main_19.cpp:41
msgid "Open the Adjourned game dialog box"
msgstr "کادر محاوره‌ای بازی متوقف‌شده را باز کنید"

#: main_19.cpp:43
msgid "Adjourned games"
msgstr "بازی‌های به تعویق افتاده"

#: main_19.cpp:45
msgid "Adjourned game file name"
msgstr "نام فایل بازی به تعویق افتاده"

#: main_19.cpp:47
msgid "Select adjourned game .pgn filename"
msgstr "نام فایل .pgn بازی متوقف شده را انتخاب کنید"

#: main_19.cpp:49
msgid "Load"
msgstr "بار"

#: main_19.cpp:51
msgid "Enter the PGN adjourn game file name"
msgstr "نام فایل بازی PGN adjourn را وارد کنید"

#: main_19.cpp:52
msgid "Save the current game as adjouned"
msgstr "بازی فعلی را به عنوان بازی لغو شده ذخیره کنید"

#: main_19.cpp:53
msgid "Load the adjourned game as current"
msgstr "بازی متوقف شده را به عنوان بازی فعلی بارگذاری کنید"

#: main_19.cpp:55
msgid "This dialog box allows you to adjourn a game and restart it later."
msgstr "این کادر محاوره‌ای به شما امکان می‌دهد بازی را به تعویق بیندازید و بعداً آن را دوباره شروع کنید."

#: main_19.cpp:57
msgid "Click the < Save > button to save the current game."
msgstr "برای ذخیره بازی فعلی، روی دکمه <ذخیره> کلیک کنید."

#: main_19.cpp:59
msgid "You can them choose the PGN file for saving the game in"
msgstr "شما می‌توانید فایل PGN را برای ذخیره بازی انتخاب کنید."

#: main_19.cpp:61
msgid "and then you can enter the game details."
msgstr "و سپس می‌توانید جزئیات بازی را وارد کنید."

#: main_19.cpp:63
msgid "Click the < Load > button to load a previously stored game."
msgstr "برای بارگذاری یک بازی ذخیره شده قبلی، روی دکمه <بارگذاری> کلیک کنید."

#: main_19.cpp:65
msgid "As before you choose the PGN file to load the game from,"
msgstr "مانند قبل، فایل PGN را برای بارگذاری بازی انتخاب کنید،"

#: main_19.cpp:67
msgid "and then you can pick the game that you want."
msgstr "و سپس می‌توانید بازی مورد نظر خود را انتخاب کنید."

#: main_19.cpp:69
msgid "If you click < Ok > the game will be loaded, ready for playing."
msgstr "اگر روی <تأیید> کلیک کنید، بازی بارگذاری شده و آماده‌ی اجرا خواهد بود."

#: main_19.cpp:71
msgid "Then pick < Play white > or < Play black > depending on which colour"
msgstr "سپس بسته به اینکه کدام رنگ را انتخاب کنید، <بازی با رنگ سفید> یا <بازی با رنگ مشکی> را انتخاب کنید."

#: main_19.cpp:73
msgid "you had in the adjourned game."
msgstr "شما در بازیِ به تعویق افتاده داشتید."

#: main_19.cpp:75
msgid "Adjourned games can also be restarted from the rated game dialog box."
msgstr "بازی‌های متوقف‌شده را می‌توان از طریق کادر محاوره‌ای بازی دارای رتبه‌بندی نیز مجدداً شروع کرد."

#: main_19.cpp:77
msgid "If you load a game from there, it will be automatically ready for play,"
msgstr "اگر یک بازی را از آنجا بارگذاری کنید، به طور خودکار آماده پخش خواهد بود،"

#: main_19.cpp:79
msgid "although your clock will not start until you make a move."
msgstr "اگرچه ساعت شما تا زمانی که حرکتی نکنید، شروع به کار نخواهد کرد."

#: main_19.cpp:81
msgid "Adjourn game dialog box"
msgstr "کادر محاوره‌ای توقف بازی"

#: main_19.cpp:83
msgid "Error writing clock config file"
msgstr "خطا در نوشتن فایل پیکربندی ساعت"

#: main_19.cpp:85
msgid "Invalid PGN file name"
msgstr "نام فایل PGN نامعتبر است"

#: main_19.cpp:87
msgid "Cannot open clock config file"
msgstr "فایل پیکربندی ساعت باز نمی‌شود"

#: main_19.cpp:89
msgid "Adjourned game saved"
msgstr "بازی لغو شده ذخیره شد"

#: main_19.cpp:91
msgid "Adjourned game loaded"
msgstr "بازی لغو شده بارگذاری شد"

#: main_19.cpp:93
msgid "Error reading clock configuration file, operation cancelled"
msgstr "خطا در خواندن فایل پیکربندی ساعت، عملیات لغو شد"

#: main_19.cpp:95
msgid "Could not open clock configuration file, operation cancelled"
msgstr "فایل پیکربندی ساعت باز نشد، عملیات لغو شد"

#: main_19.cpp:97
msgid "Could not find clock configuration file, operation cancelled"
msgstr "فایل پیکربندی ساعت پیدا نشد، عملیات لغو شد"

#: main_19.cpp:99
msgid "Press < Ok > to transfer the game to the board"
msgstr "برای انتقال بازی به صفحه بازی، <تایید> را فشار دهید."

#: main_19.cpp:101
msgid "Adjourned game options"
msgstr "گزینه‌های بازی به تعویق افتاده"
