#: main_19.cpp:3
msgid "Start next time in normal screen"
msgstr "התחל בפעם הבאה במסך רגיל"

#: main_19.cpp:7
msgid "Start next time in full screen mode"
msgstr "התחל בפעם הבאה במצב מסך מלא"

#: main_19.cpp:9
msgid "If you exit the program from the menu, then the program"
msgstr "אם תצאו מהתוכנית מהתפריט, אז התוכנית"

#: main_19.cpp:11
msgid "will restart in normal 2d screen mode."
msgstr "יופעל מחדש במצב מסך דו-ממדי רגיל."

#: main_19.cpp:13
msgid "If you exit the program from the engine window toolbar,"
msgstr "אם תצא מהתוכנית מסרגל הכלים של חלון המנוע,"

#: main_19.cpp:15
msgid "then the program will restart in full screen mode."
msgstr "לאחר מכן התוכנית תופעל מחדש במצב מסך מלא."

#: main_19.cpp:17
msgid "Alternative - click to take back the reply move and play an alternative move instead."
msgstr "אלטרנטיבה - לחץ כדי לבטל את מהלך התגובה ולשחק מהלך חלופי במקום זאת."

#: main_19.cpp:19
msgid "To over-ride the default behaviour of this option"
msgstr "כדי לעקוף את אופן הפעולה המוגדר כברירת מחדל של אפשרות זו"

#: main_19.cpp:21
msgid "Hold down < Ctrl > for the next alternative move in the list"
msgstr "החזק את <Ctrl> ללחיצה על המהלך החלופי הבא ברשימה"

#: main_19.cpp:23
msgid "Hold down < Shift > for a random alternative move"
msgstr "החזק את <Shift> ללחיצה על המקש עבור מהלך חלופי אקראי"

#: main_19.cpp:25
msgid "Hold down < Ctrl > and < Shift > for the best alternative move"
msgstr "החזק את <Ctrl> ו-<Shift> ללחיצה כדי לקבל את המהלך החלופי הטוב ביותר"

#: main_19.cpp:27
msgid "on the keyboard, select < File > < Exit 3d > from the main menu,"
msgstr "במקלדת, בחר <קובץ> <יציאה תלת-ממדית> מהתפריט הראשי,"

#: main_19.cpp:29
msgid "To exit the program from the 3d screen, select < File > < Exit program >"
msgstr "כדי לצאת מהתוכנית מהמסך התלת-ממדי, בחר < קובץ > < יציאה מתוכנית >"

#: main_19.cpp:31
msgid "If the want to the program to restart in 3d graphics mode next time,"
msgstr "אם ברצונך שהתוכנית תופעל מחדש במצב גרפיקה תלת-ממדית בפעם הבאה,"

#: main_19.cpp:33
msgid "then hold down the < Ctrl > key when you select this option."
msgstr "לאחר מכן, החזק את מקש <Ctrl> לחוץ בעת בחירת אפשרות זו."

#: main_19.cpp:35
msgid "Adjourned games  -  Click to load a previously adjourned game."
msgstr "משחקים נדחו - לחץ כדי לטעון משחק שנדחה בעבר."

#: main_19.cpp:37
msgid "Load an adjourned game"
msgstr "טעינת משחק שהושהה"

#: main_19.cpp:39
msgid "Adjourn game"
msgstr "דחיית המשחק"

#: main_19.cpp:41
msgid "Open the Adjourned game dialog box"
msgstr "פתח את תיבת הדו-שיח "משחק נדחה""

#: main_19.cpp:43
msgid "Adjourned games"
msgstr "משחקים נדחו"

#: main_19.cpp:45
msgid "Adjourned game file name"
msgstr "שם קובץ המשחק הנדחה"

#: main_19.cpp:47
msgid "Select adjourned game .pgn filename"
msgstr "בחר שם קובץ .pgn של משחק שהושהה"

#: main_19.cpp:49
msgid "Load"
msgstr "לִטעוֹן"

#: main_19.cpp:51
msgid "Enter the PGN adjourn game file name"
msgstr "הזן את שם קובץ משחק הדחייה של PGN"

#: main_19.cpp:52
msgid "Save the current game as adjouned"
msgstr "שמור את המשחק הנוכחי כנדחה"

#: main_19.cpp:53
msgid "Load the adjourned game as current"
msgstr "טען את המשחק שהודחה כמשחק נוכחי"

#: main_19.cpp:55
msgid "This dialog box allows you to adjourn a game and restart it later."
msgstr "תיבת דו-שיח זו מאפשרת לך להשהות משחק ולהתחיל אותו מאוחר יותר."

#: main_19.cpp:57
msgid "Click the < Save > button to save the current game."
msgstr "לחץ על כפתור <שמור> כדי לשמור את המשחק הנוכחי."

#: main_19.cpp:59
msgid "You can them choose the PGN file for saving the game in"
msgstr "אתה יכול לבחור את קובץ ה-PGN לשמירת המשחק"

#: main_19.cpp:61
msgid "and then you can enter the game details."
msgstr "ואז תוכל להזין את פרטי המשחק."

#: main_19.cpp:63
msgid "Click the < Load > button to load a previously stored game."
msgstr "לחץ על כפתור <טען> כדי לטעון משחק שאוחסן בעבר."

#: main_19.cpp:65
msgid "As before you choose the PGN file to load the game from,"
msgstr "כמו קודם, בחרתם את קובץ ה-PGN שממנו צריך לטעון את המשחק,"

#: main_19.cpp:67
msgid "and then you can pick the game that you want."
msgstr "ואז תוכל לבחור את המשחק שאתה רוצה."

#: main_19.cpp:69
msgid "If you click < Ok > the game will be loaded, ready for playing."
msgstr "אם תלחץ על <אישור> המשחק ייטען, מוכן למשחק."

#: main_19.cpp:71
msgid "Then pick < Play white > or < Play black > depending on which colour"
msgstr "לאחר מכן בחר <שחק לבן> או <שחק שחור> בהתאם לצבע"

#: main_19.cpp:73
msgid "you had in the adjourned game."
msgstr "היה לך במשחק שהפסיק לפעול."

#: main_19.cpp:75
msgid "Adjourned games can also be restarted from the rated game dialog box."
msgstr "ניתן להפעיל מחדש משחקים שהודחו גם מתיבת הדו-שיח של המשחק המדורג."

#: main_19.cpp:77
msgid "If you load a game from there, it will be automatically ready for play,"
msgstr "אם תטען משחק משם, הוא יהיה מוכן אוטומטית למשחק,"

#: main_19.cpp:79
msgid "although your clock will not start until you make a move."
msgstr "למרות שהשעון שלך לא יתחיל עד שתבצע מהלך."

#: main_19.cpp:81
msgid "Adjourn game dialog box"
msgstr "תיבת הדו-שיח "דחיית משחק""

#: main_19.cpp:83
msgid "Error writing clock config file"
msgstr "שגיאה בכתיבת קובץ הגדרות השעון"

#: main_19.cpp:85
msgid "Invalid PGN file name"
msgstr "שם קובץ PGN לא חוקי"

#: main_19.cpp:87
msgid "Cannot open clock config file"
msgstr "לא ניתן לפתוח את קובץ הגדרות השעון"

#: main_19.cpp:89
msgid "Adjourned game saved"
msgstr "המשחק שהודחה נשמר"

#: main_19.cpp:91
msgid "Adjourned game loaded"
msgstr "המשחק שהודחה נטען"

#: main_19.cpp:93
msgid "Error reading clock configuration file, operation cancelled"
msgstr "שגיאה בקריאת קובץ תצורת השעון, הפעולה בוטלה"

#: main_19.cpp:95
msgid "Could not open clock configuration file, operation cancelled"
msgstr "לא ניתן היה לפתוח את קובץ תצורת השעון, הפעולה בוטלה"

#: main_19.cpp:97
msgid "Could not find clock configuration file, operation cancelled"
msgstr "לא ניתן היה למצוא את קובץ תצורת השעון, הפעולה בוטלה"

#: main_19.cpp:99
msgid "Press < Ok > to transfer the game to the board"
msgstr "לחץ על < אישור > כדי להעביר את המשחק ללוח"

#: main_19.cpp:101
msgid "Adjourned game options"
msgstr "אפשרויות משחק דחוי"
