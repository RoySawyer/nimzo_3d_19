#: main_19.cpp:3
msgid "Start next time in normal screen"
msgstr "Începeți data viitoare în ecranul normal"

#: main_19.cpp:7
msgid "Start next time in full screen mode"
msgstr "Începeți data viitoare în modul ecran complet"

#: main_19.cpp:9
msgid "If you exit the program from the menu, then the program"
msgstr "Dacă ieșiți din program din meniu, atunci programul"

#: main_19.cpp:11
msgid "will restart in normal 2d screen mode."
msgstr "va reporni în modul normal de ecran 2D."

#: main_19.cpp:13
msgid "If you exit the program from the engine window toolbar,"
msgstr "Dacă ieșiți din program din bara de instrumente a ferestrei motorului,"

#: main_19.cpp:15
msgid "then the program will restart in full screen mode."
msgstr "apoi programul va reporni în modul ecran complet."

#: main_19.cpp:17
msgid "Alternative - click to take back the reply move and play an alternative move instead."
msgstr "Alternativă - faceți clic pentru a anula mutarea de răspuns și a juca o mutare alternativă în schimb."

#: main_19.cpp:19
msgid "To over-ride the default behaviour of this option"
msgstr "Pentru a ignora comportamentul implicit al acestei opțiuni"

#: main_19.cpp:21
msgid "Hold down < Ctrl > for the next alternative move in the list"
msgstr "Țineți apăsată tasta <Ctrl> pentru următoarea mișcare alternativă din listă"

#: main_19.cpp:23
msgid "Hold down < Shift > for a random alternative move"
msgstr "Țineți apăsat <Shift> pentru o mișcare alternativă aleatorie"

#: main_19.cpp:25
msgid "Hold down < Ctrl > and < Shift > for the best alternative move"
msgstr "Țineți apăsate tastele <Ctrl> și <Shift> pentru cea mai bună mișcare alternativă"

#: main_19.cpp:27
msgid "on the keyboard, select < File > < Exit 3d > from the main menu,"
msgstr "pe tastatură, selectați <Fișier> <Ieșire 3d> din meniul principal,"

#: main_19.cpp:29
msgid "To exit the program from the 3d screen, select < File > < Exit program >"
msgstr "Pentru a ieși din programul din ecranul 3D, selectați <Fișier> <Ieșire program>"

#: main_19.cpp:31
msgid "If the want to the program to restart in 3d graphics mode next time,"
msgstr "Dacă doriți ca programul să repornească în modul grafică 3D data viitoare,"

#: main_19.cpp:33
msgid "then hold down the < Ctrl > key when you select this option."
msgstr "apoi țineți apăsată tasta <Ctrl> când selectați această opțiune."

#: main_19.cpp:35
msgid "Adjourned games  -  Click to load a previously adjourned game."
msgstr "Jocuri amânate - Faceți clic pentru a încărca un joc amânat anterior."

#: main_19.cpp:37
msgid "Load an adjourned game"
msgstr "Încărcați un joc amânat"

#: main_19.cpp:39
msgid "Adjourn game"
msgstr "Amânarea jocului"

#: main_19.cpp:41
msgid "Open the Adjourned game dialog box"
msgstr "Deschideți caseta de dialog Joc amânat"

#: main_19.cpp:43
msgid "Adjourned games"
msgstr "Jocuri amânate"

#: main_19.cpp:45
msgid "Adjourned game file name"
msgstr "Numele fișierului jocului amânat"

#: main_19.cpp:47
msgid "Select adjourned game .pgn filename"
msgstr "Selectați numele fișierului .pgn al jocului amânat"

#: main_19.cpp:49
msgid "Load"
msgstr "Încărca"

#: main_19.cpp:51
msgid "Enter the PGN adjourn game file name"
msgstr "Introduceți numele fișierului jocului de amânare PGN"

#: main_19.cpp:52
msgid "Save the current game as adjouned"
msgstr "Salvează jocul curent ca încheiat"

#: main_19.cpp:53
msgid "Load the adjourned game as current"
msgstr "Încarcă jocul amânat ca fiind curent"

#: main_19.cpp:55
msgid "This dialog box allows you to adjourn a game and restart it later."
msgstr "Această casetă de dialog vă permite să întrerupeți un joc și să îl reluați mai târziu."

#: main_19.cpp:57
msgid "Click the < Save > button to save the current game."
msgstr "Faceți clic pe butonul <Salvare> pentru a salva jocul curent."

#: main_19.cpp:59
msgid "You can them choose the PGN file for saving the game in"
msgstr "Puteți alege fișierul PGN pentru salvarea jocului în"

#: main_19.cpp:61
msgid "and then you can enter the game details."
msgstr "și apoi puteți introduce detaliile jocului."

#: main_19.cpp:63
msgid "Click the < Load > button to load a previously stored game."
msgstr "Faceți clic pe butonul <Încărcare> pentru a încărca un joc stocat anterior."

#: main_19.cpp:65
msgid "As before you choose the PGN file to load the game from,"
msgstr "Ca și înainte, alegeți fișierul PGN din care să încărcați jocul,"

#: main_19.cpp:67
msgid "and then you can pick the game that you want."
msgstr "și apoi poți alege jocul pe care îl dorești."

#: main_19.cpp:69
msgid "If you click < Ok > the game will be loaded, ready for playing."
msgstr "Dacă dați clic pe <Ok>, jocul se va încărca, gata de jucat."

#: main_19.cpp:71
msgid "Then pick < Play white > or < Play black > depending on which colour"
msgstr "Apoi alegeți < Joacă alb > sau < Joacă negru > în funcție de culoare"

#: main_19.cpp:73
msgid "you had in the adjourned game."
msgstr "ai avut în meciul amânat."

#: main_19.cpp:75
msgid "Adjourned games can also be restarted from the rated game dialog box."
msgstr "Jocurile amânate pot fi reluate și din caseta de dialog Joc evaluat."

#: main_19.cpp:77
msgid "If you load a game from there, it will be automatically ready for play,"
msgstr "Dacă încarci un joc de acolo, acesta va fi automat gata de utilizare,"

#: main_19.cpp:79
msgid "although your clock will not start until you make a move."
msgstr "deși ceasul tău nu va porni până nu faci o mișcare."

#: main_19.cpp:81
msgid "Adjourn game dialog box"
msgstr "Caseta de dialog Amânare joc"

#: main_19.cpp:83
msgid "Error writing clock config file"
msgstr "Eroare la scrierea fișierului de configurare a ceasului"

#: main_19.cpp:85
msgid "Invalid PGN file name"
msgstr "Nume de fișier PGN nevalid"

#: main_19.cpp:87
msgid "Cannot open clock config file"
msgstr "Nu se poate deschide fișierul de configurare a ceasului"

#: main_19.cpp:89
msgid "Adjourned game saved"
msgstr "Meci amânat salvat"

#: main_19.cpp:91
msgid "Adjourned game loaded"
msgstr "Joc amânat încărcat"

#: main_19.cpp:93
msgid "Error reading clock configuration file, operation cancelled"
msgstr "Eroare la citirea fișierului de configurare a ceasului, operațiune anulată"

#: main_19.cpp:95
msgid "Could not open clock configuration file, operation cancelled"
msgstr "Nu s-a putut deschide fișierul de configurare a ceasului, operațiunea a fost anulată."

#: main_19.cpp:97
msgid "Could not find clock configuration file, operation cancelled"
msgstr "Nu s-a găsit fișierul de configurare a ceasului, operațiunea a fost anulată."

#: main_19.cpp:99
msgid "Press < Ok > to transfer the game to the board"
msgstr "Apăsați <Ok> pentru a transfera jocul pe tablă"

#: main_19.cpp:101
msgid "Adjourned game options"
msgstr "Opțiuni de joc amânate"
