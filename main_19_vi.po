#: main_19.cpp:3
msgid "Start next time in normal screen"
msgstr "Lần sau hãy bắt đầu ở chế độ màn hình bình thường"

#: main_19.cpp:7
msgid "Start next time in full screen mode"
msgstr "Lần sau hãy bắt đầu ở chế độ toàn màn hình"

#: main_19.cpp:9
msgid "If you exit the program from the menu, then the program"
msgstr "Nếu bạn thoát khỏi chương trình từ menu, thì chương trình sẽ dừng hoạt động."

#: main_19.cpp:11
msgid "will restart in normal 2d screen mode."
msgstr "Sẽ khởi động lại ở chế độ màn hình 2D bình thường."

#: main_19.cpp:13
msgid "If you exit the program from the engine window toolbar,"
msgstr "Nếu bạn thoát chương trình từ thanh công cụ của cửa sổ engine,"

#: main_19.cpp:15
msgid "then the program will restart in full screen mode."
msgstr "Sau đó, chương trình sẽ khởi động lại ở chế độ toàn màn hình."

#: main_19.cpp:17
msgid "Alternative - click to take back the reply move and play an alternative move instead."
msgstr "Phương án thay thế - nhấp chuột để thu hồi nước đi đáp trả và chơi một nước đi khác thay thế."

#: main_19.cpp:19
msgid "To over-ride the default behaviour of this option"
msgstr "Để ghi đè lên hành vi mặc định của tùy chọn này"

#: main_19.cpp:21
msgid "Hold down < Ctrl > for the next alternative move in the list"
msgstr "Nhấn giữ phím <Ctrl> để chuyển sang bước di chuyển thay thế tiếp theo trong danh sách."

#: main_19.cpp:23
msgid "Hold down < Shift > for a random alternative move"
msgstr "Giữ phím <Shift> để chọn một động tác ngẫu nhiên khác."

#: main_19.cpp:25
msgid "Hold down < Ctrl > and < Shift > for the best alternative move"
msgstr "Nhấn giữ phím <Ctrl> và <Shift> để có thao tác thay thế tốt nhất."

#: main_19.cpp:27
msgid "on the keyboard, select < File > < Exit 3d > from the main menu,"
msgstr "Trên bàn phím, chọn <Tệp> <Thoát 3D> từ menu chính."

#: main_19.cpp:29
msgid "To exit the program from the 3d screen, select < File > < Exit program >"
msgstr "Để thoát khỏi chương trình trên màn hình 3D, chọn <Tệp> <Thoát chương trình>."

#: main_19.cpp:31
msgid "If the want to the program to restart in 3d graphics mode next time,"
msgstr "Nếu muốn chương trình khởi động lại ở chế độ đồ họa 3D vào lần sau,"

#: main_19.cpp:33
msgid "then hold down the < Ctrl > key when you select this option."
msgstr "Sau đó, giữ phím <Ctrl> khi bạn chọn tùy chọn này."

#: main_19.cpp:35
msgid "Adjourned games  -  Click to load a previously adjourned game."
msgstr "Các trận đấu bị hoãn - Nhấp vào đây để xem trận đấu đã bị hoãn trước đó."

#: main_19.cpp:37
msgid "Load an adjourned game"
msgstr "Tải trò chơi đã hoãn"

#: main_19.cpp:39
msgid "Adjourn game"
msgstr "Hoãn trận đấu"

#: main_19.cpp:41
msgid "Open the Adjourned game dialog box"
msgstr "Mở hộp thoại Trò chơi bị hoãn"

#: main_19.cpp:43
msgid "Adjourned games"
msgstr "Các trận đấu bị hoãn"

#: main_19.cpp:45
msgid "Adjourned game file name"
msgstr "Tên tệp trò chơi bị hoãn"

#: main_19.cpp:47
msgid "Select adjourned game .pgn filename"
msgstr "Chọn tên tệp .pgn của trò chơi bị hoãn."

#: main_19.cpp:49
msgid "Load"
msgstr "Trọng tải"

#: main_19.cpp:51
msgid "Enter the PGN adjourn game file name"
msgstr "Nhập tên tệp trò chơi hoãn PGN."

#: main_19.cpp:52
msgid "Save the current game as adjouned"
msgstr "Lưu trò chơi hiện tại ở trạng thái tạm dừng."

#: main_19.cpp:53
msgid "Load the adjourned game as current"
msgstr "Tải trận đấu đã hoãn lại làm trận đấu hiện tại."

#: main_19.cpp:55
msgid "This dialog box allows you to adjourn a game and restart it later."
msgstr "Hộp thoại này cho phép bạn tạm dừng trò chơi và bắt đầu lại sau."

#: main_19.cpp:57
msgid "Click the < Save > button to save the current game."
msgstr "Nhấp vào nút < Lưu > để lưu trò chơi hiện tại."

#: main_19.cpp:59
msgid "You can them choose the PGN file for saving the game in"
msgstr "Sau đó, bạn có thể chọn tệp PGN để lưu trò chơi."

#: main_19.cpp:61
msgid "and then you can enter the game details."
msgstr "Sau đó bạn có thể nhập thông tin chi tiết trò chơi."

#: main_19.cpp:63
msgid "Click the < Load > button to load a previously stored game."
msgstr "Nhấp vào nút < Tải > để tải trò chơi đã lưu trước đó."

#: main_19.cpp:65
msgid "As before you choose the PGN file to load the game from,"
msgstr "Như trước đây, bạn chọn tệp PGN để tải trò chơi từ đó."

#: main_19.cpp:67
msgid "and then you can pick the game that you want."
msgstr "Sau đó bạn có thể chọn trò chơi mà bạn muốn chơi."

#: main_19.cpp:69
msgid "If you click < Ok > the game will be loaded, ready for playing."
msgstr "Nếu bạn nhấn < OK >, trò chơi sẽ được tải và sẵn sàng để chơi."

#: main_19.cpp:71
msgid "Then pick < Play white > or < Play black > depending on which colour"
msgstr "Sau đó chọn < Chơi trắng > hoặc < Chơi đen > tùy thuộc vào màu sắc"

#: main_19.cpp:73
msgid "you had in the adjourned game."
msgstr "bạn đã có trong trận đấu bị hoãn."

#: main_19.cpp:75
msgid "Adjourned games can also be restarted from the rated game dialog box."
msgstr "Các trận đấu bị hoãn cũng có thể được tiếp tục từ hộp thoại xếp hạng trận đấu."

#: main_19.cpp:77
msgid "If you load a game from there, it will be automatically ready for play,"
msgstr "Nếu bạn tải trò chơi từ đó, trò chơi sẽ tự động sẵn sàng để chơi."

#: main_19.cpp:79
msgid "although your clock will not start until you make a move."
msgstr "Mặc dù đồng hồ của bạn sẽ không bắt đầu đếm ngược cho đến khi bạn thực hiện một nước đi."

#: main_19.cpp:81
msgid "Adjourn game dialog box"
msgstr "Hộp thoại hoãn trò chơi"

#: main_19.cpp:83
msgid "Error writing clock config file"
msgstr "Lỗi khi ghi tệp cấu hình đồng hồ"

#: main_19.cpp:85
msgid "Invalid PGN file name"
msgstr "Tên tệp PGN không hợp lệ"

#: main_19.cpp:87
msgid "Cannot open clock config file"
msgstr "Không thể mở tệp cấu hình đồng hồ."

#: main_19.cpp:89
msgid "Adjourned game saved"
msgstr "Trận đấu bị hoãn đã được lưu"

#: main_19.cpp:91
msgid "Adjourned game loaded"
msgstr "Trận đấu bị hoãn đã được tải"

#: main_19.cpp:93
msgid "Error reading clock configuration file, operation cancelled"
msgstr "Lỗi khi đọc tệp cấu hình đồng hồ, thao tác bị hủy bỏ"

#: main_19.cpp:95
msgid "Could not open clock configuration file, operation cancelled"
msgstr "Không thể mở tệp cấu hình đồng hồ, thao tác đã bị hủy."

#: main_19.cpp:97
msgid "Could not find clock configuration file, operation cancelled"
msgstr "Không tìm thấy tệp cấu hình đồng hồ, thao tác đã bị hủy."

#: main_19.cpp:99
msgid "Press < Ok > to transfer the game to the board"
msgstr "Nhấn < OK > để chuyển trò chơi sang bàn cờ."

#: main_19.cpp:101
msgid "Adjourned game options"
msgstr "Các lựa chọn hoãn trận đấu"
