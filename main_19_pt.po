#: main_19.cpp:3
msgid "Start next time in normal screen"
msgstr "Na próxima vez, inicie no modo de tela normal."

#: main_19.cpp:7
msgid "Start next time in full screen mode"
msgstr "Na próxima vez, inicie em modo de tela cheia."

#: main_19.cpp:9
msgid "If you exit the program from the menu, then the program"
msgstr "Se você sair do programa pelo menu, então o programa"

#: main_19.cpp:11
msgid "will restart in normal 2d screen mode."
msgstr "Será reiniciado no modo de tela 2D normal."

#: main_19.cpp:13
msgid "If you exit the program from the engine window toolbar,"
msgstr "Se você sair do programa pela barra de ferramentas da janela do mecanismo,"

#: main_19.cpp:15
msgid "then the program will restart in full screen mode."
msgstr "Em seguida, o programa será reiniciado em modo de tela cheia."

#: main_19.cpp:17
msgid "Alternative - click to take back the reply move and play an alternative move instead."
msgstr "Alternativa - clique para desfazer a jogada de resposta e jogar uma jogada alternativa."

#: main_19.cpp:19
msgid "To over-ride the default behaviour of this option"
msgstr "Para substituir o comportamento padrão desta opção"

#: main_19.cpp:21
msgid "Hold down < Ctrl > for the next alternative move in the list"
msgstr "Mantenha pressionada a tecla < Ctrl > para a próxima opção da lista."

#: main_19.cpp:23
msgid "Hold down < Shift > for a random alternative move"
msgstr "Mantenha pressionada a tecla < Shift > para um movimento alternativo aleatório"

#: main_19.cpp:25
msgid "Hold down < Ctrl > and < Shift > for the best alternative move"
msgstr "Mantenha pressionadas as teclas <Ctrl> e <Shift> para a melhor alternativa de movimento."

#: main_19.cpp:27
msgid "on the keyboard, select < File > < Exit 3d > from the main menu,"
msgstr "No teclado, selecione < Arquivo > < Sair do 3D > no menu principal."

#: main_19.cpp:29
msgid "To exit the program from the 3d screen, select < File > < Exit program >"
msgstr "Para sair do programa na tela 3D, selecione < Arquivo > < Sair do programa >"

#: main_19.cpp:31
msgid "If the want to the program to restart in 3d graphics mode next time,"
msgstr "Se você deseja que o programa reinicie no modo gráfico 3D na próxima vez,"

#: main_19.cpp:33
msgid "then hold down the < Ctrl > key when you select this option."
msgstr "Em seguida, mantenha pressionada a tecla < Ctrl > ao selecionar esta opção."

#: main_19.cpp:35
msgid "Adjourned games  -  Click to load a previously adjourned game."
msgstr "Jogos adiados - Clique para carregar um jogo que foi adiado anteriormente."

#: main_19.cpp:37
msgid "Load an adjourned game"
msgstr "Carregar um jogo adiado"

#: main_19.cpp:39
msgid "Adjourn game"
msgstr "Encerrar o jogo"

#: main_19.cpp:41
msgid "Open the Adjourned game dialog box"
msgstr "Abra a caixa de diálogo Jogo Adiado"

#: main_19.cpp:43
msgid "Adjourned games"
msgstr "Jogos adiados"

#: main_19.cpp:45
msgid "Adjourned game file name"
msgstr "Nome do arquivo do jogo adiado"

#: main_19.cpp:47
msgid "Select adjourned game .pgn filename"
msgstr "Selecione o nome do arquivo .pgn do jogo adiado."

#: main_19.cpp:49
msgid "Load"
msgstr "Carregar"

#: main_19.cpp:51
msgid "Enter the PGN adjourn game file name"
msgstr "Digite o nome do arquivo PGN do jogo de encerramento."

#: main_19.cpp:52
msgid "Save the current game as adjouned"
msgstr "Salve o jogo atual conforme encerrado."

#: main_19.cpp:53
msgid "Load the adjourned game as current"
msgstr "Carregar o jogo adiado como jogo atual"

#: main_19.cpp:55
msgid "This dialog box allows you to adjourn a game and restart it later."
msgstr "Esta caixa de diálogo permite que você suspenda um jogo e o reinicie mais tarde."

#: main_19.cpp:57
msgid "Click the < Save > button to save the current game."
msgstr "Clique no botão < Salvar > para salvar o jogo atual."

#: main_19.cpp:59
msgid "You can them choose the PGN file for saving the game in"
msgstr "Você pode então escolher o arquivo PGN para salvar o jogo em"

#: main_19.cpp:61
msgid "and then you can enter the game details."
msgstr "Em seguida, você poderá inserir os detalhes do jogo."

#: main_19.cpp:63
msgid "Click the < Load > button to load a previously stored game."
msgstr "Clique no botão < Carregar > para carregar um jogo salvo anteriormente."

#: main_19.cpp:65
msgid "As before you choose the PGN file to load the game from,"
msgstr "Assim como antes, você escolhe o arquivo PGN para carregar o jogo,"

#: main_19.cpp:67
msgid "and then you can pick the game that you want."
msgstr "E então você pode escolher o jogo que quiser."

#: main_19.cpp:69
msgid "If you click < Ok > the game will be loaded, ready for playing."
msgstr "Ao clicar em < Ok >, o jogo será carregado e estará pronto para jogar."

#: main_19.cpp:71
msgid "Then pick < Play white > or < Play black > depending on which colour"
msgstr "Em seguida, selecione <Reproduzir branco> ou <Reproduzir preto>, dependendo da cor."

#: main_19.cpp:73
msgid "you had in the adjourned game."
msgstr "você tinha no jogo adiado."

#: main_19.cpp:75
msgid "Adjourned games can also be restarted from the rated game dialog box."
msgstr "Jogos adiados também podem ser reiniciados a partir da caixa de diálogo de jogo classificado."

#: main_19.cpp:77
msgid "If you load a game from there, it will be automatically ready for play,"
msgstr "Se você carregar um jogo a partir daí, ele estará automaticamente pronto para jogar."

#: main_19.cpp:79
msgid "although your clock will not start until you make a move."
msgstr "embora seu cronômetro não comece a funcionar até que você faça um movimento."

#: main_19.cpp:81
msgid "Adjourn game dialog box"
msgstr "Caixa de diálogo "Adiar jogo""

#: main_19.cpp:83
msgid "Error writing clock config file"
msgstr "Erro ao gravar o arquivo de configuração do relógio"

#: main_19.cpp:85
msgid "Invalid PGN file name"
msgstr "Nome de arquivo PGN inválido"

#: main_19.cpp:87
msgid "Cannot open clock config file"
msgstr "Não foi possível abrir o arquivo de configuração do relógio."

#: main_19.cpp:89
msgid "Adjourned game saved"
msgstr "Jogo adiado salvo"

#: main_19.cpp:91
msgid "Adjourned game loaded"
msgstr "Jogo adiado carregado"

#: main_19.cpp:93
msgid "Error reading clock configuration file, operation cancelled"
msgstr "Erro ao ler o arquivo de configuração do relógio, operação cancelada."

#: main_19.cpp:95
msgid "Could not open clock configuration file, operation cancelled"
msgstr "Não foi possível abrir o arquivo de configuração do relógio, operação cancelada."

#: main_19.cpp:97
msgid "Could not find clock configuration file, operation cancelled"
msgstr "Não foi possível encontrar o arquivo de configuração do relógio; operação cancelada."

#: main_19.cpp:99
msgid "Press < Ok > to transfer the game to the board"
msgstr "Pressione < Ok > para transferir o jogo para o tabuleiro"

#: main_19.cpp:101
msgid "Adjourned game options"
msgstr "Opções de jogo adiadas"
